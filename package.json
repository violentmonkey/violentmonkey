{
  "name": "feature-injector",
  "description": "Feature Injector",
  "version": "0.80.1",
  "scripts": {
    "prepare": "husky install",
    "dev": "gulp dev",
    "build:bundle": "cross-env NODE_ENV=production NODE_OPTIONS=--no-deprecation gulp build",
    "build": "cross-env BROWSER=chrome run-s ci build:bundle",
    "build:firefox": "cross-env BROWSER=firefox run-s ci build:bundle",
    "build:selfHosted": "cross-env BROWSER=chrome TARGET=selfHosted BETA=1 run-s ci build:bundle",
    "build:selfHosted:firefox": "cross-env BROWSER=firefox TARGET=selfHosted BETA=1 run-s ci build:bundle",
    "analyze": "cross-env RUN_ENV=analyze run-s build",
    "i18n": "gulp i18n",
    "copyI18n": "gulp copyI18n",
    "lint": "run-s lint:js lint:yml",
    "lint:js": "eslint --ext .js,.vue . --cache",
    "lint:yml": "gulp check",
    "test": "cross-env BABEL_ENV=test TEST=test BROWSER= jest test",
    "ci": "run-p lint test",
    "bumpVersion": "gulp bump",
    "bump": "run-s ci \"bumpVersion --commit\"",
    "preversion": "run-s ci \"bumpVersion --reset\""
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@babel/core": "^7.29.0",
